{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__sagol__write_report",
        "hooks": [
          {
            "type": "command",
            "command": "bun run scripts/strip-report.ts"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "sagol": {
      "command": "bun",
      "args": ["run", "src/mcp/server.ts"]
    }
  }
}
